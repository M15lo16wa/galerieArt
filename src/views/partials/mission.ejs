<!-- ========== PLATFORM MISSION ========== -->
<section class="mission">

  <!-- Hero with background image -->
  <div class="mission__hero">
    <h2 class="mission__hero-title">Qu'est-ce qu'ArtExpo&nbsp;?</h2>
    <p class="mission__hero-sub">
      "Une plateforme dédiée à l'art, aux artistes et aux collectionneurs du monde entier"
    </p>
  </div>

  <!-- 4 feature columns -->
  <div class="mission__features">

    <div class="mission__feature">
      <div class="mission__feature-icon">◎</div>
      <h3 class="mission__feature-title">Œuvres Originales</h3>
      <p class="mission__feature-desc">Découvrez des milliers d'œuvres authentiques d'artistes du monde entier et filtres intelligents.</p>
    </div>

    <div class="mission__feature">
      <div class="mission__feature-icon">✦</div>
      <h3 class="mission__feature-title">Sélections Exclusives</h3>
      <p class="mission__feature-desc">Des œuvres soigneusement sélectionnées par notre équipe de commissaires d'art.</p>
    </div>

    <div class="mission__feature">
      <div class="mission__feature-icon">◈</div>
      <h3 class="mission__feature-title">Artistes Émergents</h3>
      <p class="mission__feature-desc">Soutenez les créateurs de demain et explorez les talents les plus prometteurs.</p>
    </div>

    <div class="mission__feature">
      <div class="mission__feature-icon">⊕</div>
      <h3 class="mission__feature-title">Accès International</h3>
      <p class="mission__feature-desc">Artistes confirmés et émergents issus de plus de 80 pays sur tous les continents.</p>
    </div>

  </div>

  <!-- Description block -->
  <div class="mission__description">
    <p>
      Avec pour mission de créer une place de marché en ligne simple, sécurisée et accessible à tous,
      ArtExpo réunit artistes, galeries et collectionneurs autour d'une passion commune.
      Notre plateforme vous propose des œuvres originales d'artistes internationaux émergents et
      confirmés, expédiées dans le monde entier. Profitez d'une sélection unique d'œuvres d'art
      originales et d'impressions haut de gamme qui feront de parfaits cadeaux ou décoreront vos
      espaces avec authenticité.
    </p>
    <p class="mission__description-cta">
      <strong>EXPLOREZ &amp; COMMENCEZ À SUIVRE VOS ARTISTES PRÉFÉRÉS&nbsp;!</strong><br>
      Sculpteurs &bull; Photographes &bull; Peintres &bull; Artistes contemporains &bull;
      Arts premiers &bull; Street Art &bull; Céramique &bull; Arts numériques
    </p>
  </div>

</section>

<!-- ========== NEWSLETTER ========== -->
<section class="newsletter">
  <div class="newsletter__inner">

    <div class="newsletter__text">
      <span class="newsletter__brand">ARTEXPO</span>
      <h2 class="newsletter__title">Lettre d'Information</h2>
      <p class="newsletter__desc">
        Recevez notre lettre d'information pour les amateurs d'art et les collectionneurs.
      </p>
    </div>

    <form class="newsletter__form" action="#" method="POST">
      <input
        type="email"
        name="email"
        placeholder="Votre adresse email"
        class="newsletter__input"
        required
      >
      <button type="submit" class="newsletter__btn">S'inscrire</button>
    </form>

  </div>
</section>
