<%
  const _mode     = typeof filterMode !== 'undefined' ? filterMode : 'full';
  const _cat      = (typeof query !== 'undefined' && query.cat)       ? query.cat       : 'peinture';
  const _style    = (typeof query !== 'undefined' && query.style)     ? query.style     : null;
  const _tech     = (typeof query !== 'undefined' && query.technique) ? query.technique : null;
  const _sujet    = (typeof query !== 'undefined' && query.sujet)     ? query.sujet     : null;
  const _prix     = (typeof query !== 'undefined' && query.prix)      ? query.prix      : null;

  function labelCat(slug) {
    const map = { peinture:'Peinture', sculpture:'Sculpture', photographie:'Photographie', dessin:'Dessin' };
    return map[slug] || slug;
  }
  function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1).replace(/-/g,' ') : ''; }
%>

<!-- ================================================================
     MODE COMPACT  —  barre de filtres actifs (page expositions)
     ================================================================ -->
<% if (_mode === 'compact') { %>

<div class="cat-filtres cat-filtres--compact">
  <div class="cat-compact__inner">

    <!-- Fil d'Ariane / filtres actifs -->
    <div class="cat-compact__pills">
      <a href="/amateur/catalog" class="cat-pill cat-pill--back">Catalogue</a>
      <span class="cat-compact__sep">›</span>
      <a href="/expositions?cat=<%= _cat %>" class="cat-pill cat-pill--cat"><%= labelCat(_cat) %></a>

      <% if (_style) { %>
        <span class="cat-compact__sep">›</span>
        <span class="cat-pill cat-pill--filter">
          <%= capitalize(_style) %>
          <a href="/expositions?cat=<%= _cat %>" class="cat-pill__remove" title="Retirer ce filtre">&times;</a>
        </span>
      <% } %>
      <% if (_tech) { %>
        <span class="cat-compact__sep">›</span>
        <span class="cat-pill cat-pill--filter">
          <%= capitalize(_tech) %>
          <a href="/expositions?cat=<%= _cat %>" class="cat-pill__remove" title="Retirer ce filtre">&times;</a>
        </span>
      <% } %>
      <% if (_sujet) { %>
        <span class="cat-compact__sep">›</span>
        <span class="cat-pill cat-pill--filter">
          <%= capitalize(_sujet) %>
          <a href="/expositions?cat=<%= _cat %>" class="cat-pill__remove" title="Retirer ce filtre">&times;</a>
        </span>
      <% } %>
      <% if (_prix) { %>
        <span class="cat-compact__sep">›</span>
        <span class="cat-pill cat-pill--filter">
          <%= capitalize(_prix) %>
          <a href="/expositions?cat=<%= _cat %>" class="cat-pill__remove" title="Retirer ce filtre">&times;</a>
        </span>
      <% } %>
    </div>

    <!-- Lien modifier les filtres -->
    <a href="/amateur/catalog?cat=<%= _cat %>" class="cat-compact__modify">Modifier les filtres</a>

  </div>
</div>

