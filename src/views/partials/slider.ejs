<section class="slider">

  <div class="slider__track">

    <!-- Slide 1 -->
    <div class="slider__slide">
      <div class="slider__panel">
        <div class="slider__panel-body">
          <span class="slider__tag">Arts Premiers</span>
          <h2 class="slider__title">Masques &amp; Traditions</h2>
          <p class="slider__desc">Plongez dans l'univers des arts ancestraux, témoins vivants de cultures millénaires à travers le monde.</p>
        </div>
        <div class="slider__nav">
          <button class="slider__arrow slider__arrow--prev" aria-label="Précédent">&#8249;</button>
          <button class="slider__arrow slider__arrow--next" aria-label="Suivant">&#8250;</button>
        </div>
      </div>
      <div class="slider__visual">
        <img src="/images/image-section-centrale.jpg" alt="Masques traditionnels">
        <a href="#" class="slider__cta">Découvrez</a>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="slider__slide">
      <div class="slider__panel">
        <div class="slider__panel-body">
          <span class="slider__tag">Street Art</span>
          <h2 class="slider__title">Artistes en Action</h2>
          <p class="slider__desc">Rencontrez les créateurs qui façonnent notre époque, de la rue aux galeries les plus prestigieuses.</p>
        </div>
        <div class="slider__nav">
          <button class="slider__arrow slider__arrow--prev" aria-label="Précédent">&#8249;</button>
          <button class="slider__arrow slider__arrow--next" aria-label="Suivant">&#8250;</button>
        </div>
      </div>
      <div class="slider__visual">
        <img src="/images/image-section-centrale-2.jpg" alt="Artiste peignant une fresque">
        <a href="#" class="slider__cta">Découvrez</a>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="slider__slide">
      <div class="slider__panel">
        <div class="slider__panel-body">
          <span class="slider__tag">Expositions</span>
          <h2 class="slider__title">Soirées &amp; Vernissages</h2>
          <p class="slider__desc">Vivez des expériences artistiques uniques au cœur de galeries d'exception, entre lumières et créations.</p>
        </div>
        <div class="slider__nav">
          <button class="slider__arrow slider__arrow--prev" aria-label="Précédent">&#8249;</button>
          <button class="slider__arrow slider__arrow--next" aria-label="Suivant">&#8250;</button>
        </div>
      </div>
      <div class="slider__visual">
        <img src="/images/image-section-centrale-3.jpg" alt="Galerie avec ambiance lumineuse">
        <a href="#" class="slider__cta">Découvrez</a>
      </div>
    </div>

    <!-- Slide 4 -->
    <div class="slider__slide">
      <div class="slider__panel">
        <div class="slider__panel-body">
          <span class="slider__tag">Galeries d'Art</span>
          <h2 class="slider__title">Face aux Oeuvres</h2>
          <p class="slider__desc">Découvrez les œuvres qui vous parlent, exposées dans les meilleures galeries à travers le monde.</p>
        </div>
        <div class="slider__nav">
          <button class="slider__arrow slider__arrow--prev" aria-label="Précédent">&#8249;</button>
          <button class="slider__arrow slider__arrow--next" aria-label="Suivant">&#8250;</button>
        </div>
      </div>
      <div class="slider__visual">
        <img src="/images/image-section-centrale-4.jpg" alt="Visiteur face à des portraits">
        <a href="#" class="slider__cta">Découvrez</a>
      </div>
    </div>

  </div>

  <!-- Dots -->
  <div class="slider__dots">
    <button class="slider__dot slider__dot--active" aria-label="Slide 1"></button>
    <button class="slider__dot" aria-label="Slide 2"></button>
    <button class="slider__dot" aria-label="Slide 3"></button>
    <button class="slider__dot" aria-label="Slide 4"></button>
  </div>

</section>

<script src="/js/slider.js" defer></script>
