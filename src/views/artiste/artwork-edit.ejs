<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier l'oeuvre | ArtExpo</title>
    <link rel="stylesheet" href="/css/artiste.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="artiste-page">

    <aside class="sidebar" id="sidebar">
        <a href="/" class="sidebar__logo">ArtExpo</a>
        <div class="sidebar__mini-profil">
            <div class="sidebar__mini-avatar"><i class="fa-solid fa-user"></i></div>
            <p class="sidebar__mini-nom"><%= artiste.prenom %> <%= artiste.nom %></p>
            <span class="sidebar__mini-role">Artiste</span>
        </div>
        <nav class="sidebar__nav">
            <a href="/artiste/dashboard" class="sidebar__lien">
                <i class="fa-solid fa-gauge"></i><span>Tableau de bord</span>
            </a>
            <a href="/artiste/profile" class="sidebar__lien">
                <i class="fa-solid fa-user-pen"></i><span>Mon Profil</span>
            </a>
            <a href="/artiste/my-artworks" class="sidebar__lien sidebar__lien--actif">
                <i class="fa-solid fa-palette"></i><span>Mes Oeuvres</span>
            </a>
            <a href="/artiste/exhibitions" class="sidebar__lien">
                <i class="fa-solid fa-building-columns"></i><span>Mes Expositions</span>
            </a>
            <a href="/artiste/sales" class="sidebar__lien">
                <i class="fa-solid fa-chart-line"></i><span>Mes Ventes</span>
            </a>
        </nav>
        <div class="sidebar__pied">
            <a href="/auth/login" class="sidebar__deconnexion">
                <i class="fa-solid fa-right-from-bracket"></i><span>Se déconnecter</span>
            </a>
        </div>
    </aside>

    <div class="sidebar-voile" id="sidebarVoile"></div>

    <main class="artiste-contenu">

        <!-- Fil d'ariane -->
        <nav class="fil-ariane">
            <a href="/artiste/my-artworks" class="fil-ariane__lien">Mes Oeuvres</a>
            <i class="fa-solid fa-chevron-right fil-ariane__separateur"></i>
            <!-- TODO: afficher le titre de l'oeuvre ici -->
            <span class="fil-ariane__courant">Modifier l'oeuvre</span>
        </nav>

        <div class="page-entete">
            <h1 class="page-titre">Modifier l'oeuvre</h1>
            <p class="page-sous-titre">Mettez à jour les informations de votre création</p>
        </div>

        <div class="formulaire-carte">
            <!-- TODO: passer l'objet oeuvre depuis la route pour pré-remplir les champs -->
            <form method="POST" action="/artiste/artwork/edit" class="formulaire-profil" id="formulaireEditOeuvre">

                <!-- Titre -->
                <div class="champ">
                    <label class="champ__label champ__label--obligatoire" for="champTitre">Titre de l'oeuvre</label>
                    <input class="champ__input" type="text" id="champTitre" name="titre"
                        placeholder="Ex : Harmonie bleue n°3" required>
                </div>

                <!-- Discipline et Année -->
                <div class="formulaire-grille">
                    <div class="champ">
                        <label class="champ__label champ__label--obligatoire" for="champDiscipline">Discipline</label>
                        <select class="champ__input" id="champDiscipline" name="discipline" required>
                            <option value="" disabled selected>Choisir une discipline</option>
                            <option value="peinture">Peinture</option>
                            <option value="sculpture">Sculpture</option>
                            <option value="photographie">Photographie</option>
                            <option value="dessin">Dessin</option>
                            <option value="gravure">Gravure</option>
                            <option value="numerique">Art numérique</option>
                            <option value="installation">Installation</option>
                            <option value="autre">Autre</option>
                        </select>
                    </div>
                    <div class="champ">
                        <label class="champ__label" for="champAnnee">Année de création</label>
                        <input class="champ__input" type="number" id="champAnnee" name="annee"
                            placeholder="Ex : 2024" min="1900" max="2099">
                    </div>
                </div>

                <!-- Description -->
                <div class="champ">
                    <label class="champ__label" for="champDescription">Description</label>
                    <textarea class="champ__textarea" id="champDescription" name="description"
                        rows="4" placeholder="Décrivez votre oeuvre, son contexte, sa technique..."></textarea>
                </div>

                <!-- Prix et Disponibilité -->
                <div class="formulaire-grille">
                    <div class="champ">
                        <label class="champ__label champ__label--obligatoire" for="champPrix">Prix (€)</label>
                        <input class="champ__input" type="number" id="champPrix" name="prix"
                            placeholder="Ex : 850" min="0" step="0.01" required>
                    </div>
                    <div class="champ">
                        <label class="champ__label champ__label--obligatoire" for="champDisponibilite">Disponibilité</label>
                        <select class="champ__input" id="champDisponibilite" name="disponibilite" required>
                            <option value="disponible">Disponible à la vente</option>
                            <option value="exposition">En exposition</option>
                            <option value="vendu">Vendu</option>
                        </select>
                    </div>
                </div>

                <!-- Dimensions -->
                <div class="formulaire-grille formulaire-grille--3">
                    <div class="champ">
                        <label class="champ__label" for="champLargeur">Largeur (cm)</label>
                        <input class="champ__input" type="number" id="champLargeur" name="largeur"
                            placeholder="Ex : 60" min="0">
                    </div>
                    <div class="champ">
                        <label class="champ__label" for="champHauteur">Hauteur (cm)</label>
                        <input class="champ__input" type="number" id="champHauteur" name="hauteur"
                            placeholder="Ex : 80" min="0">
                    </div>
                    <div class="champ">
                        <label class="champ__label" for="champProfondeur">Profondeur (cm)</label>
                        <input class="champ__input" type="number" id="champProfondeur" name="profondeur"
                            placeholder="Ex : 5" min="0">
                    </div>
                </div>

                <!-- Upload image -->
                <div class="champ">
                    <label class="champ__label" for="champImage">Remplacer l'image</label>
                    <div class="zone-upload" id="zoneUpload">
                        <i class="fa-solid fa-cloud-arrow-up zone-upload__icone"></i>
                        <p class="zone-upload__texte">Glissez une nouvelle image ici ou</p>
                        <label for="champImage" class="btn btn--secondaire zone-upload__btn">Parcourir</label>
                        <input type="file" id="champImage" name="image" accept="image/*" class="zone-upload__input">
                        <p class="zone-upload__hint">JPG, PNG ou WEBP — max 5 Mo</p>
                    </div>
                </div>

                <div class="formulaire-actions">
                    <a href="/artiste/my-artworks" class="btn btn--secondaire">Annuler</a>
                    <button type="submit" class="btn btn--principal">
                        <i class="fa-solid fa-check"></i> Enregistrer les modifications
                    </button>
                </div>

            </form>
        </div>

        <!-- Zone danger — suppression -->
        <div class="zone-danger">
            <h3 class="zone-danger__titre">Zone de danger</h3>
            <p class="zone-danger__texte">La suppression de cette oeuvre est irréversible.</p>
            <form method="POST" action="/artiste/artwork/delete" onsubmit="return confirm('Confirmer la suppression ?')">
                <button type="submit" class="btn btn--danger">
                    <i class="fa-solid fa-trash"></i> Supprimer l'oeuvre
                </button>
            </form>
        </div>

    </main>

    <button class="btn-menu-mobile" id="btnMenuMobile" aria-label="Ouvrir le menu">
        <i class="fa-solid fa-bars"></i>
    </button>

    <script>
        var btnMenuMobile = document.getElementById('btnMenuMobile');
        var sidebar       = document.getElementById('sidebar');
        var sidebarVoile  = document.getElementById('sidebarVoile');
        btnMenuMobile.addEventListener('click', function() {
            sidebar.classList.toggle('sidebar--ouverte');
            sidebarVoile.classList.toggle('sidebar-voile--visible');
        });
        sidebarVoile.addEventListener('click', function() {
            sidebar.classList.remove('sidebar--ouverte');
            sidebarVoile.classList.remove('sidebar-voile--visible');
        });
    </script>

</body>
</html>
