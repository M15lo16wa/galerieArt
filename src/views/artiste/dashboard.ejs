<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de bord | ArtExpo</title>
    <link rel="stylesheet" href="/css/artiste.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="artiste-page">

    <aside class="sidebar" id="sidebar">
        <a href="/" class="sidebar__logo">ArtExpo</a>
        <div class="sidebar__mini-profil">
            <div class="sidebar__mini-avatar"><i class="fa-solid fa-user"></i></div>
            <p class="sidebar__mini-nom"><%= artiste.prenom %> <%= artiste.nom %></p>
            <span class="sidebar__mini-role">Artiste</span>
        </div>
        <nav class="sidebar__nav">
            <a href="/artiste/dashboard" class="sidebar__lien sidebar__lien--actif">
                <i class="fa-solid fa-gauge"></i><span>Tableau de bord</span>
            </a>
            <a href="/artiste/profile" class="sidebar__lien">
                <i class="fa-solid fa-user-pen"></i><span>Mon Profil</span>
            </a>
            <a href="/artiste/my-artworks" class="sidebar__lien">
                <i class="fa-solid fa-palette"></i><span>Mes Oeuvres</span>
            </a>
            <a href="/artiste/exhibitions" class="sidebar__lien">
                <i class="fa-solid fa-building-columns"></i><span>Mes Expositions</span>
            </a>
            <a href="/artiste/sales" class="sidebar__lien">
                <i class="fa-solid fa-chart-line"></i><span>Mes Ventes</span>
            </a>
        </nav>
        <div class="sidebar__pied">
            <a href="/auth/login" class="sidebar__deconnexion">
                <i class="fa-solid fa-right-from-bracket"></i><span>Se déconnecter</span>
            </a>
        </div>
    </aside>

    <div class="sidebar-voile" id="sidebarVoile"></div>

    <main class="artiste-contenu">

        <div class="page-entete">
            <h1 class="page-titre">Bonjour, <%= artiste.prenom || 'Artiste' %></h1>
            <p class="page-sous-titre">Voici un aperçu de votre activité sur ArtExpo</p>
        </div>

        <!-- Statistiques résumé -->
        <div class="dashboard-stats">
            <div class="dashboard-stat-carte">
                <div class="dashboard-stat-carte__icone">
                    <i class="fa-solid fa-palette"></i>
                </div>
                <div class="dashboard-stat-carte__corps">
                    <span class="dashboard-stat-carte__valeur"><%= artiste.stats.artworkCount %></span>
                    <span class="dashboard-stat-carte__libelle">Oeuvres publiées</span>
                </div>
            </div>
            <div class="dashboard-stat-carte">
                <div class="dashboard-stat-carte__icone">
                    <i class="fa-solid fa-building-columns"></i>
                </div>
                <div class="dashboard-stat-carte__corps">
                    <span class="dashboard-stat-carte__valeur"><%= artiste.stats.exhibitionCount %></span>
                    <span class="dashboard-stat-carte__libelle">Expositions</span>
                </div>
            </div>
            <div class="dashboard-stat-carte">
                <div class="dashboard-stat-carte__icone">
                    <i class="fa-solid fa-chart-line"></i>
                </div>
                <div class="dashboard-stat-carte__corps">
                    <span class="dashboard-stat-carte__valeur"><%= artiste.stats.salesCount %></span>
                    <span class="dashboard-stat-carte__libelle">Ventes réalisées</span>
                </div>
            </div>
        </div>

        <!-- Accès rapide -->
        <section class="section">
            <h2 class="section__titre">Actions rapides</h2>
            <div class="acces-rapide">
                <a href="/artiste/artwork/add" class="carte-action">
                    <div class="carte-action__icone"><i class="fa-solid fa-plus"></i></div>
                    <div class="carte-action__corps">
                        <p class="carte-action__titre">Ajouter une oeuvre</p>
                        <p class="carte-action__description">Publier une nouvelle création</p>
                    </div>
                    <i class="fa-solid fa-chevron-right carte-action__fleche"></i>
                </a>
                <a href="/artiste/exhibition/add" class="carte-action">
                    <div class="carte-action__icone"><i class="fa-solid fa-calendar-plus"></i></div>
                    <div class="carte-action__corps">
                        <p class="carte-action__titre">Créer une exposition</p>
                        <p class="carte-action__description">Organiser une nouvelle exposition</p>
                    </div>
                    <i class="fa-solid fa-chevron-right carte-action__fleche"></i>
                </a>
                <a href="/artiste/my-artworks" class="carte-action">
                    <div class="carte-action__icone"><i class="fa-solid fa-palette"></i></div>
                    <div class="carte-action__corps">
                        <p class="carte-action__titre">Gérer mes oeuvres</p>
                        <p class="carte-action__description">Modifier ou supprimer vos créations</p>
                    </div>
                    <i class="fa-solid fa-chevron-right carte-action__fleche"></i>
                </a>
                <a href="/artiste/sales" class="carte-action">
                    <div class="carte-action__icone"><i class="fa-solid fa-chart-line"></i></div>
                    <div class="carte-action__corps">
                        <p class="carte-action__titre">Voir mes ventes</p>
                        <p class="carte-action__description">Suivre vos transactions</p>
                    </div>
                    <i class="fa-solid fa-chevron-right carte-action__fleche"></i>
                </a>
            </div>
        </section>

        <!-- Activité récente -->
        <section class="section">
            <h2 class="section__titre">Activité récente</h2>
            <div class="activite-vide">
                <i class="fa-regular fa-clock activite-vide__icone"></i>
                <p class="activite-vide__texte">Aucune activité récente</p>
                <p class="activite-vide__sous-texte">Vos dernières actions apparaîtront ici</p>
            </div>
        </section>

    </main>

    <button class="btn-menu-mobile" id="btnMenuMobile" aria-label="Ouvrir le menu">
        <i class="fa-solid fa-bars"></i>
    </button>

    <script>
        var btnMenuMobile = document.getElementById('btnMenuMobile');
        var sidebar       = document.getElementById('sidebar');
        var sidebarVoile  = document.getElementById('sidebarVoile');
        btnMenuMobile.addEventListener('click', function() {
            sidebar.classList.toggle('sidebar--ouverte');
            sidebarVoile.classList.toggle('sidebar-voile--visible');
        });
        sidebarVoile.addEventListener('click', function() {
            sidebar.classList.remove('sidebar--ouverte');
            sidebarVoile.classList.remove('sidebar-voile--visible');
        });
    </script>

</body>
</html>
